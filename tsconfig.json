{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist",
    "strict": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "sourceMap": true
  },
  "include": ["app.ts", "bin/**/*.ts", "app/**/*.ts", "routes/**/*.ts", "config/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
